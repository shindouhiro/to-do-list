{
  "name": "calendar-todo-app",
  "type": "module",
  "version": "0.0.2",
  "private": true,
  "description": "Calendar Todo App - Monorepo",
  "author": "",
  "license": "MIT",
  "keywords": [
    "todo",
    "calendar",
    "monorepo"
  ],
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:client": "pnpm --filter @todo-app/client dev",
    "dev:server": "pnpm --filter @todo-app/server dev",
    "build": "pnpm -r build",
    "build:client": "pnpm --filter @todo-app/client build",
    "build:server": "pnpm --filter @todo-app/server build",
    "start:server": "pnpm --filter @todo-app/server start",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "clean": "pnpm -r exec rm -rf node_modules dist .tanstack && rm -rf node_modules",
    "install:all": "pnpm install",
    "tauri": "tauri",
    "tauri:prepare": "node scripts/prepare-tauri-resources.mjs",
    "tauri:dev": "node scripts/run-tauri.mjs dev",
    "tauri:build": "pnpm tauri:prepare && node scripts/run-tauri.mjs build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "catalog:",
    "@antfu/eslint-config": "catalog:",
    "@eslint-react/eslint-plugin": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "prettier": "catalog:"
  }
}
