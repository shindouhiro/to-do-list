{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-dev.mjs",
    "beforeBuildCommand": "node scripts/tauri-before-build.mjs",
    "devPath": "http://localhost:3000",
    "distDir": "../packages/client/dist"
  },
  "package": {
    "productName": "GTD",
    "version": "0.0.3"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": true,
        "message": true
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "GTD",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "bundle": {
      "active": true,
      "identifier": "com.hikaru.gtd",
      "targets": [
        "app",
        "msi",
        "nsis"
      ],
      "resources": [
        "resources/client/**/*"
      ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
